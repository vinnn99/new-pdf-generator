HOST=127.0.0.1
PORT=3334
NODE_ENV=testing
APP_URL=http://${HOST}:${PORT}
CACHE_VIEWS=false
APP_KEY=TEST_APP_KEY_FOR_AUTOMATED_TESTS_ONLY

DB_CONNECTION=sqlite
DB_DATABASE=./tmp/test.sqlite

QUEUE_DRIVER=database
QUEUE_AUTOSTART=false

SESSION_DRIVER=cookie
HASH_DRIVER=bcrypt

SMTP_HOST=smtp.example.test
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=test@example.test
SMTP_PASS=test
MAIL_FROM=test@example.test
